# ──────────────────────────────────────────────────
# Claim Verification System — Environment Config
# ──────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# .env is gitignored and never committed.

# ── Model Configuration ──
OLLAMA_MODEL=llava:7b
OLLAMA_URL=http://localhost:11434

# ── Cloud API (Optional) ──
# If set, agents will use an OpenAI-compatible REST call to this endpoint instead of Ollama.
# CLOUD_MODEL=gemini-2.5-flash
# API_KEY=
# API_BASE_URL=https://api.groq.com/openai/v1

# ── Sampling Parameters ──
MODEL_TEMPERATURE=1.0
MODEL_TOP_P=0.95
MODEL_TOP_K=64

# ── Dataset Paths (relative to repo root) ──
CLAIMS_CSV=dataset/claims.csv
SAMPLE_CSV=dataset/sample_claims.csv
EVIDENCE_CSV=dataset/evidence_requirements.csv
HISTORY_CSV=dataset/user_history.csv
IMAGES_DIR=dataset

# ── Output Paths ──
OUTPUT_CSV=dataset/output.csv
EVAL_REPORT=code/evaluation/evaluation_report.md
